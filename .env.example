# Local MySQL configuration. Do not commit a real .env file.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=zamato
DB_USER=root
DB_PASSWORD=replace-with-your-password

# Railway sets PORT automatically. Leave it unset locally to use 8001.
# PORT=8001

# Set to true only when intentionally altering an existing development schema.
DB_SYNC_ALTER=false
